projection;
strict ( 1 );

use draft;

define behavior for ZC_ASLRAP_CERTIFPRODUTCT alias Certificate
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _stats { create; with draft; }
}

define behavior for ZC_ASLRAP_CERTIFSTPRODUCT alias CertificadoST
{
  use delete;

  use association _certif { with draft; }
}